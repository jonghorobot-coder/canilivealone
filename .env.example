# ================================
# 독립점수 환경변수 설정
# ================================

# Google Analytics 4 Measurement ID
# 발급: https://analytics.google.com > 관리 > 속성 > 데이터 스트림 > 측정 ID
# 형식: G-XXXXXXXXXX
VITE_GA_ID=G-XXXXXXXXXX

# Supabase 프로젝트 URL
# 발급: https://app.supabase.com > 프로젝트 선택 > Settings > API > Project URL
VITE_SUPABASE_URL=https://your-project.supabase.co

# Supabase Anonymous Key (공개 키)
# 발급: https://app.supabase.com > 프로젝트 선택 > Settings > API > anon public
VITE_SUPABASE_ANON_KEY=your-anon-key

# Kakao JavaScript Key
# 발급: https://developers.kakao.com > 애플리케이션 > 앱 키 > JavaScript 키
VITE_KAKAO_KEY=your-kakao-javascript-key
